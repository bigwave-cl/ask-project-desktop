{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Ask Project",
  "version": "26.605.1",
  "identifier": "cn.askmewhy.project",
  "build": {
    "beforeDevCommand": "pnpm dev",
    "devUrl": "http://localhost:4000",
    "beforeBuildCommand": "pnpm build",
    "frontendDist": "../out"
  },
  "app": {
    "windows": [
      {
        "title": "Ask Project",
        "label": "main",
        "width": 1180,
        "height": 760,
        "minWidth": 960,
        "minHeight": 640,
        "devtools": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all"
  }
}
