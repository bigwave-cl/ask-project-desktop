{
  "name": "desktop",
  "version": "26.605.1",
  "description": "Ask Project desktop application powered by Electron, Rust, React, and Next.js.",
  "author": "Ask Project",
  "private": true,
  "main": "dist/dist-electron/main.js",
  "scripts": {
    "dev": "next dev --port 4000",
    "clean:dist-electron": "node scripts/cleanBuildArtifacts.mjs dist-electron",
    "clean:dist-web": "node scripts/cleanBuildArtifacts.mjs dist-web",
    "clean:dist-rust": "node scripts/cleanBuildArtifacts.mjs dist-rust",
    "clean:dist-native": "node scripts/cleanBuildArtifacts.mjs dist-native",
    "clean:dist-release": "node scripts/cleanBuildArtifacts.mjs dist-release",
    "build": "pnpm clean:dist-web && next build",
    "start": "next start --port 4000",
    "lint": "eslint",
    "native:compile": "cargo build --manifest-path native/Cargo.toml --target-dir dist/dist-rust",
    "native:build": "pnpm clean:dist-rust && pnpm native:compile",
    "native:build:release": "pnpm clean:dist-rust && cargo build --release --manifest-path native/Cargo.toml --target-dir dist/dist-rust",
    "native:check": "cargo check --manifest-path native/Cargo.toml --target-dir dist/dist-rust",
    "electron:compile": "tsc -p electron/tsconfig.json",
    "electron:build": "pnpm clean:dist-electron && pnpm electron:compile",
    "electron:dev": "pnpm native:compile && pnpm electron:compile && electron dist/dist-electron/main.js",
    "electron:dev:tools": "pnpm native:compile && pnpm electron:compile && ASK_PROJECT_ELECTRON_DEVTOOLS=1 electron dist/dist-electron/main.js",
    "electron:smoke": "pnpm native:compile && pnpm electron:compile && electron dist/dist-electron/main.js --smoke-test",
    "release:prepare": "pnpm build && pnpm electron:build",
    "release": "node scripts/releaseDesktop.mjs current",
    "release:all": "node scripts/releaseDesktop.mjs all",
    "release:mac": "node scripts/releaseDesktop.mjs mac",
    "release:mac:arm64": "node scripts/releaseDesktop.mjs mac:arm64",
    "release:mac:x64": "node scripts/releaseDesktop.mjs mac:x64",
    "release:win": "node scripts/releaseDesktop.mjs win",
    "release:win:x64": "node scripts/releaseDesktop.mjs win:x64"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4.3.0",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "class-variance-authority": "^0.7.1",
    "clipboard": "^2.0.11",
    "clsx": "^2.1.1",
    "electron": "^42.3.3",
    "electron-builder": "^26.15.2",
    "eslint": "^9",
    "eslint-config-next": "16.2.6",
    "lucide-react": "^1.17.0",
    "next": "16.2.6",
    "radix-ui": "^1.4.3",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.6.0",
    "tailwindcss": "^4.3.0",
    "tw-animate-css": "^1.4.0",
    "typescript": "^5.9.3"
  }
}
