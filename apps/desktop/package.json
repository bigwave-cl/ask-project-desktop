{
  "name": "desktop",
  "productName": "Ask Project",
  "version": "26.605.1",
  "description": "Ask Project desktop application powered by Electron, Rust, React, and Next.js.",
  "author": "Ask Project",
  "private": true,
  "main": "dist/dist-electron/main.js",
  "scripts": {
    "dev": "next dev --port 4000",
    "clean": "node scripts/cleanBuildArtifacts.mjs",
    "build": "pnpm clean dist-web && next build",
    "start": "next start --port 4000",
    "lint": "eslint",
    "native:compile": "cargo build --manifest-path native/Cargo.toml --target-dir dist/dist-rust",
    "native:build": "pnpm clean dist-rust && pnpm native:compile",
    "native:check": "cargo check --manifest-path native/Cargo.toml --target-dir dist/dist-rust",
    "electron:compile": "tsc -p electron/tsconfig.json",
    "electron:build": "pnpm clean dist-electron && pnpm electron:compile",
    "electron:dev": "pnpm native:compile && pnpm electron:compile && node scripts/runElectronDev.mjs",
    "electron:smoke": "pnpm electron:dev -- --smoke-test",
    "release": "node scripts/releaseDesktop.mjs"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4.3.0",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "class-variance-authority": "^0.7.1",
    "clipboard": "^2.0.11",
    "clsx": "^2.1.1",
    "electron": "^42.3.3",
    "electron-builder": "^26.15.2",
    "eslint": "^9",
    "eslint-config-next": "16.2.6",
    "lucide-react": "^1.17.0",
    "next": "16.2.6",
    "radix-ui": "^1.4.3",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.6.0",
    "tailwindcss": "^4.3.0",
    "tw-animate-css": "^1.4.0",
    "typescript": "^5.9.3"
  }
}
