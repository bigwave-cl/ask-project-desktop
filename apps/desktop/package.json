{
  "name": "desktop",
  "version": "26.605.1",
  "private": true,
  "scripts": {
    "dev": "next dev --port 4000",
    "build": "next build",
    "start": "next start --port 4000",
    "lint": "eslint",
    "native:build": "cargo build --manifest-path native/Cargo.toml",
    "native:check": "cargo check --manifest-path native/Cargo.toml",
    "electron:dev": "pnpm native:build && electron electron/main.cjs",
    "electron:dev:tools": "pnpm native:build && ASK_PROJECT_ELECTRON_DEVTOOLS=1 electron electron/main.cjs",
    "electron:smoke": "pnpm native:build && electron electron/main.cjs --smoke-test"
  },
  "dependencies": {
    "class-variance-authority": "^0.7.1",
    "clipboard": "^2.0.11",
    "clsx": "^2.1.1",
    "lucide-react": "^1.17.0",
    "next": "16.2.6",
    "radix-ui": "^1.4.3",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.6.0",
    "tw-animate-css": "^1.4.0"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4.3.0",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "electron": "^42.3.3",
    "eslint": "^9",
    "eslint-config-next": "16.2.6",
    "tailwindcss": "^4.3.0",
    "typescript": "^5.9.3"
  }
}
