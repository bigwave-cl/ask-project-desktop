{
  "name": "ask-project",
  "version": "26.605.1",
  "private": true,
  "packageManager": "pnpm@11.1.0",
  "scripts": {
    "dev:desktop": "node scripts/devDesktop.mjs",
    "dev:desktop:agent": "node scripts/devDesktop.mjs --agent",
    "dev:desktop:tools": "node scripts/devDesktop.mjs --tools",
    "debug:desktop:agent": "node scripts/debugDesktopAgent.mjs",
    "build:desktop": "pnpm --filter desktop build",
    "release:desktop": "pnpm --filter desktop release",
    "dev:web": "pnpm --filter web dev",
